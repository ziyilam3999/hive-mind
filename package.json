{
  "name": "hive-mind",
  "version": "0.19.0",
  "description": "PRD-driven orchestrator with multi-chain reasoning and closed feedback loop",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hive-mind": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/build-dashboard.mjs",
    "build:dashboard": "node scripts/build-dashboard.mjs",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "progress": "tsx scripts/update-progress.ts",
    "postinstall": "node scripts/install-hooks.cjs"
  },
  "keywords": [
    "cli",
    "orchestrator",
    "prd",
    "ai",
    "claude",
    "multi-agent"
  ],
  "author": "Ziyil",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
